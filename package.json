{
  "name": "sports-platform",
  "version": "1.0.0",
  "description": "Comprehensive sports management platform for clubs",
  "scripts": {
    "build": "npm run build:backend",
    "build:backend": "npm run build --workspaces --if-present",
    "build:frontend": "echo \"Frontend not implemented yet\"",
    "start": "npm run start:identity",
    "start:dev": "npm run start:dev:identity",
    "start:all": "npm run start:all:services",
    "start:dev:all": "npm run start:dev:all:services",
    "start:all:services": "concurrently -n \"identity,sports,gateway\" -c \"blue,green,yellow\" \"npm run start:identity\" \"npm run start:sports\" \"npm run start:gateway\"",
    "start:dev:all:services": "concurrently -n \"identity,sports\" -c \"blue,green\" \"npm run start:dev:identity\" \"npm run start:dev:sports\"",
    "start:gateway": "cd apps/api-gateway && npm run start:prod",
    "start:identity": "cd apps/identity-service && npm run start:prod",
    "start:sports": "cd apps/sports-service && npm run start:prod",
    "start:club": "cd apps/club-management && npm run start:prod",
    "start:communication": "cd apps/communication && npm run start:prod",
    "start:dev:gateway": "cd apps/api-gateway && npm run start:dev",
    "start:dev:identity": "cd apps/identity-service && npm run start:dev",
    "start:dev:sports": "cd apps/sports-service && npm run start:dev",
    "start:dev:club": "cd apps/club-management && npm run start:dev",
    "start:dev:communication": "cd apps/communication && npm run start:dev",
    "frontend:start": "cd frontend && npm run start",
    "frontend:build": "cd frontend && npm run build",
    "db:setup": "cd libs/database && npx prisma migrate dev",
    "db:studio": "cd libs/database && npx prisma studio",
    "db:reset": "cd libs/database && npx prisma migrate reset",
    "test": "npm run test --workspaces --if-present",
    "test:cov": "npm run test:cov --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "type-check": "tsc --noEmit --skipLibCheck",
    "build:shared": "npm run build --workspace=libs/shared",
    "install:all": "npm install && npm install --workspaces && cd frontend && npm install",
    "github:create-issues": "chmod +x scripts/create-github-issues.sh && ./scripts/create-github-issues.sh",
    "github:list-issues": "gh issue list --label user-story",
    "github:list-mvp": "gh issue list --label mvp"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.13",
    "@types/supertest": "^6.0.2",
    "@types/validator": "^13.15.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/sports-platform.git"
  },
  "keywords": [
    "sports",
    "management",
    "platform",
    "nestjs",
    "angular",
    "microservices",
    "swimming",
    "clubs"
  ],
  "author": "Sports Platform Team",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.16.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^2.28.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.16.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "validator": "^13.15.15"
  }
}
