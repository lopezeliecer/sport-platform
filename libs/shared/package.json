{
  "name": "@sports-platform/shared",
  "version": "1.0.0",
  "description": "Shared libraries for the sports platform",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "npm run build:auth && npm run build:database && npm run build:common && npm run build:audit",
    "build:auth": "cd auth && tsc",
    "build:database": "cd database && tsc",
    "build:common": "cd common && tsc",
    "build:audit": "cd audit && tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "prisma": "^6.16.1"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "@types/node": "^22.5.5"
  }
}
