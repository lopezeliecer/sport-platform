generator client {
  provider      = "prisma-client-js"
  output        = "./generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  COACH
  ADMIN
  ATHLETE
  PARENT
  MEDICAL
  DIRECTOR

  @@map("user_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum Sport {
  SWIMMING
  TRACK_FIELD
  SOCCER
  BASKETBALL
  TENNIS

  @@map("sport")
}

enum AthleteLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE

  @@map("athlete_level")
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED

  @@map("session_status")
}

enum AssignmentStatus {
  ASSIGNED
  CONFIRMED
  DECLINED
  CANCELLED

  @@map("assignment_status")
}

enum AttendanceStatus {
  SCHEDULED
  PRESENT
  ABSENT
  LATE
  EARLY_DEPARTURE

  @@map("attendance_status")
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  PARTIAL

  @@map("payment_status")
}

enum PaymentType {
  MEMBERSHIP
  TRAINING
  COMPETITION
  EQUIPMENT
  FACILITY
  OTHER

  @@map("payment_type")
}

enum CommunicationType {
  ANNOUNCEMENT
  REMINDER
  ALERT
  NEWSLETTER
  PERSONAL_MESSAGE
  EMERGENCY

  @@map("communication_type")
}

enum CommunicationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH_NOTIFICATION
  ALL_CHANNELS

  @@map("communication_channel")
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@map("message_priority")
}

enum MedicalRecordType {
  PHYSICAL_EXAM
  MEDICAL_CLEARANCE
  INJURY_REPORT
  ALLERGY_INFO
  MEDICATION
  NUTRITION_PLAN
  FITNESS_ASSESSMENT
  EMERGENCY_INFO

  @@map("medical_record_type")
}

enum ConfidentialityLevel {
  PUBLIC
  RESTRICTED
  CONFIDENTIAL

  @@map("confidentiality_level")
}

enum CompetitionType {
  INTERNAL
  REGIONAL
  NATIONAL
  INTERNATIONAL

  @@map("competition_type")
}

enum FileCategory {
  PROFILE_PICTURE
  MEDICAL_DOCUMENT
  TRAINING_VIDEO
  COMPETITION_PHOTO
  CERTIFICATE
  INVOICE
  REPORT
  OTHER

  @@map("file_category")
}

// ============================================================================
// CORE DOMAIN MODELS
// ============================================================================

model User {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email             String    @unique
  googleId          String?   @unique @map("google_id")
  name              String
  profilePicture    String?   @map("profile_picture")
  phone             String?
  emergencyContact  Json?     @map("emergency_contact")
  preferredLanguage String    @default("en") @map("preferred_language")
  timezone          String    @default("UTC")
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  userClubRoles           UserClubRole[]
  athletesAsUser          Athlete[]            @relation("AthleteUser")
  athletesAsParent        Athlete[]            @relation("AthleteParent")
  createdTrainingSessions TrainingSession[]    @relation("TrainingSessionCoach")
  recordedPerformanceData PerformanceData[]    @relation("PerformanceRecorder")
  assignedTraining        TrainingAssignment[] @relation("AssignedBy")
  sentCommunications      Communication[]      @relation("CommunicationSender")
  recordedMedicalRecords  MedicalRecord[]      @relation("MedicalRecorder")
  approvedMedicalRecords  MedicalRecord[]      @relation("MedicalApprover")
  uploadedFiles           File[]               @relation("FileUploader")
  userSessions            UserSession[]
  auditLogs               AuditLog[]
  paymentsAsUser          Payment[]            @relation("PaymentUser")
  processedPayments       Payment[]            @relation("PaymentProcessor")
  createdCompetitions     Competition[]        @relation("CompetitionCreator")
  registeredEntries       CompetitionEntry[]   @relation("EntryRegistrar")
  validatedPerformance    PerformanceData[]    @relation("PerformanceValidator")

  @@map("users")
}

model Club {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  slug             String   @unique
  description      String?
  logo             String?
  address          String?
  phone            String?
  email            String?
  website          String?
  foundedYear      Int?     @map("founded_year")
  sports           Sport[]  @default([SWIMMING])
  timezone         String   @default("UTC")
  currency         String   @default("USD")
  language         String   @default("en")
  settings         Json     @default("{}")
  isActive         Boolean  @default(true) @map("is_active")
  subscriptionTier String   @default("FREE") @map("subscription_tier")
  maxAthletes      Int      @default(100) @map("max_athletes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  userClubRoles       UserClubRole[]
  athletes            Athlete[]
  trainingTemplates   TrainingTemplate[]
  trainingSessions    TrainingSession[]
  trainingAssignments TrainingAssignment[]
  performanceData     PerformanceData[]
  competitions        Competition[]
  competitionEntries  CompetitionEntry[]
  payments            Payment[]
  communications      Communication[]
  medicalRecords      MedicalRecord[]
  files               File[]
  auditLogs           AuditLog[]

  @@map("clubs")
}

model UserClubRole {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  clubId      String    @map("club_id") @db.Uuid
  role        UserRole
  permissions String[]  @default([])
  isActive    Boolean   @default(true) @map("is_active")
  assignedBy  String?   @map("assigned_by") @db.Uuid
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId, role])
  @@index([clubId, role, isActive])
  @@map("user_club_roles")
}

model Athlete {
  id                String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId            String       @map("club_id") @db.Uuid
  userId            String?      @map("user_id") @db.Uuid
  athleteNumber     String?      @map("athlete_number")
  firstName         String       @map("first_name")
  lastName          String       @map("last_name")
  nickname          String?
  dateOfBirth       DateTime?    @map("date_of_birth") @db.Date
  gender            Gender?
  profilePicture    String?      @map("profile_picture")
  sport             Sport        @default(SWIMMING)
  category          String?
  level             AthleteLevel @default(BEGINNER)
  joinedAt          DateTime     @default(now()) @map("joined_at") @db.Date
  isActive          Boolean      @default(true) @map("is_active")
  personalBests     Json         @default("{}") @map("personal_bests")
  goals             Json         @default("{}") @map("goals")
  notes             String?
  parentId          String?      @map("parent_id") @db.Uuid
  emergencyContacts Json         @default("{}") @map("emergency_contacts")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relations
  club                Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user                User?                @relation("AthleteUser", fields: [userId], references: [id], onDelete: SetNull)
  parent              User?                @relation("AthleteParent", fields: [parentId], references: [id])
  trainingAssignments TrainingAssignment[]
  performanceData     PerformanceData[]
  competitionEntries  CompetitionEntry[]
  payments            Payment[]
  medicalRecords      MedicalRecord[]

  @@unique([clubId, athleteNumber])
  @@index([clubId, isActive])
  @@index([clubId, sport, level])
  @@map("athletes")
}

// ============================================================================
// SPORTS DOMAIN MODELS
// ============================================================================

model TrainingTemplate {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId      String        @map("club_id") @db.Uuid
  name        String
  description String?
  sport       Sport
  category    String
  level       AthleteLevel?
  duration    Int? // Duration in minutes
  structure   Json          @default("{}")
  equipment   String[]      @default([])
  tags        String[]      @default([])
  isPublic    Boolean       @default(false) @map("is_public")
  createdBy   String        @map("created_by") @db.Uuid
  usageCount  Int           @default(0) @map("usage_count")
  rating      Decimal       @default(0.0) @db.Decimal(3, 2)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  club             Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  trainingSessions TrainingSession[]

  @@index([clubId, sport, category])
  @@index([clubId, isPublic])
  @@map("training_templates")
}

model TrainingSession {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId            String        @map("club_id") @db.Uuid
  templateId        String?       @map("template_id") @db.Uuid
  title             String
  description       String?
  sport             Sport
  category          String
  level             AthleteLevel?
  scheduledAt       DateTime      @map("scheduled_at")
  duration          Int // Duration in minutes
  location          String?
  maxParticipants   Int?          @map("max_participants")
  isRecurring       Boolean       @default(false) @map("is_recurring")
  recurrencePattern Json?         @map("recurrence_pattern")
  status            SessionStatus @default(SCHEDULED)
  actualStartTime   DateTime?     @map("actual_start_time")
  actualEndTime     DateTime?     @map("actual_end_time")
  workout           Json          @default("{}")
  equipment         String[]      @default([])
  notes             String?
  coachId           String        @map("coach_id") @db.Uuid
  assistantCoaches  String[]      @default([]) @map("assistant_coaches") @db.Uuid
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  club                Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  template            TrainingTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  coach               User                 @relation("TrainingSessionCoach", fields: [coachId], references: [id])
  trainingAssignments TrainingAssignment[]
  performanceData     PerformanceData[]

  @@index([clubId, scheduledAt])
  @@index([clubId, status])
  @@index([coachId, scheduledAt])
  @@map("training_sessions")
}

model TrainingAssignment {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId           String           @map("club_id") @db.Uuid
  sessionId        String           @map("session_id") @db.Uuid
  athleteId        String           @map("athlete_id") @db.Uuid
  assignedBy       String           @map("assigned_by") @db.Uuid
  assignedAt       DateTime         @default(now()) @map("assigned_at")
  status           AssignmentStatus @default(ASSIGNED)
  attendanceStatus AttendanceStatus @default(SCHEDULED) @map("attendance_status")
  checkedInAt      DateTime?        @map("checked_in_at")
  checkedOutAt     DateTime?        @map("checked_out_at")
  modifications    Json             @default("{}")
  coachNotes       String?          @map("coach_notes")
  athleteNotes     String?          @map("athlete_notes")
  rating           Int?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  club     Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  session  TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  athlete  Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  assigner User            @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@unique([sessionId, athleteId])
  @@index([clubId, attendanceStatus])
  @@index([athleteId, assignedAt])
  @@map("training_assignments")
}

model PerformanceData {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId         String    @map("club_id") @db.Uuid
  athleteId      String    @map("athlete_id") @db.Uuid
  sessionId      String?   @map("session_id") @db.Uuid
  competitionId  String?   @map("competition_id") @db.Uuid
  recordedAt     DateTime  @default(now()) @map("recorded_at")
  recordedBy     String    @map("recorded_by") @db.Uuid
  sport          Sport
  event          String
  category       String?
  metrics        Json // Flexible sports metrics
  conditions     Json      @default("{}")
  equipment      Json      @default("{}")
  isPersonalBest Boolean   @default(false) @map("is_personal_best")
  isSeasonBest   Boolean   @default(false) @map("is_season_best")
  tags           String[]  @default([])
  notes          String?
  videoUrl       String?   @map("video_url")
  validated      Boolean   @default(false)
  validatedBy    String?   @map("validated_by") @db.Uuid
  validatedAt    DateTime? @map("validated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  athlete     Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  session     TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  competition Competition?     @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  recorder    User             @relation("PerformanceRecorder", fields: [recordedBy], references: [id])
  validator   User?            @relation("PerformanceValidator", fields: [validatedBy], references: [id])

  @@index([athleteId, recordedAt])
  @@index([clubId, recordedAt])
  @@index([clubId, sport, event])
  @@map("performance_data")
}

// ============================================================================
// COMPETITION DOMAIN MODELS
// ============================================================================

model Competition {
  id                   String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId               String          @map("club_id") @db.Uuid
  name                 String
  description          String?
  type                 CompetitionType
  sport                Sport
  level                String?
  venue                String
  startDate            DateTime        @map("start_date") @db.Date
  endDate              DateTime        @map("end_date") @db.Date
  registrationDeadline DateTime        @map("registration_deadline") @db.Date
  maxParticipants      Int?            @map("max_participants")
  ageCategories        String[]        @default([]) @map("age_categories")
  events               String[]        @default([])
  entryFee             Decimal?        @map("entry_fee") @db.Decimal(10, 2)
  status               String          @default("UPCOMING")
  results              Json            @default("{}")
  organizer            String?
  contactInfo          Json            @default("{}") @map("contact_info")
  rules                Json            @default("{}")
  createdBy            String          @map("created_by") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  // Relations
  club               Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator            User               @relation("CompetitionCreator", fields: [createdBy], references: [id])
  competitionEntries CompetitionEntry[]
  performanceData    PerformanceData[]

  @@index([clubId, startDate])
  @@index([clubId, type])
  @@map("competitions")
}

model CompetitionEntry {
  id                 String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId             String        @map("club_id") @db.Uuid
  competitionId      String        @map("competition_id") @db.Uuid
  athleteId          String        @map("athlete_id") @db.Uuid
  events             String[]
  category           String?
  seedTimes          Json          @default("{}") @map("seed_times")
  registeredAt       DateTime      @default(now()) @map("registered_at")
  registeredBy       String        @map("registered_by") @db.Uuid
  status             String        @default("PENDING")
  paymentStatus      PaymentStatus @default(PENDING) @map("payment_status")
  confirmationNumber String?       @map("confirmation_number")
  specialRequests    String?       @map("special_requests")
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  club        Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  athlete     Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  registrar   User        @relation("EntryRegistrar", fields: [registeredBy], references: [id])

  @@unique([competitionId, athleteId])
  @@index([clubId, competitionId])
  @@map("competition_entries")
}

// ============================================================================
// ADMINISTRATIVE MODELS
// ============================================================================

model Payment {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId            String        @map("club_id") @db.Uuid
  athleteId         String?       @map("athlete_id") @db.Uuid
  userId            String?       @map("user_id") @db.Uuid
  type              PaymentType
  category          String
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  description       String
  dueDate           DateTime      @map("due_date") @db.Date
  paidAt            DateTime?     @map("paid_at")
  status            PaymentStatus @default(PENDING)
  method            String?
  reference         String?
  notes             String?
  recurringSchedule Json?         @map("recurring_schedule")
  discounts         Json          @default("{}")
  taxes             Json          @default("{}")
  invoiceNumber     String?       @map("invoice_number")
  receiptUrl        String?       @map("receipt_url")
  processedBy       String?       @map("processed_by") @db.Uuid
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  athlete   Athlete? @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  user      User?    @relation("PaymentUser", fields: [userId], references: [id], onDelete: SetNull)
  processor User?    @relation("PaymentProcessor", fields: [processedBy], references: [id])

  @@index([clubId, status, dueDate])
  @@index([clubId, type])
  @@map("payments")
}

model Communication {
  id           String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId       String               @map("club_id") @db.Uuid
  type         CommunicationType
  channel      CommunicationChannel
  senderId     String               @map("sender_id") @db.Uuid
  title        String
  content      String
  recipients   Json // Array of recipient IDs or criteria
  scheduledAt  DateTime?            @map("scheduled_at")
  sentAt       DateTime?            @map("sent_at")
  status       String               @default("DRAFT")
  priority     MessagePriority      @default(NORMAL)
  tags         String[]             @default([])
  attachments  Json                 @default("{}")
  readReceipts Json                 @default("{}") @map("read_receipts")
  responses    Json                 @default("{}")
  expiresAt    DateTime?            @map("expires_at")
  isEmergency  Boolean              @default(false) @map("is_emergency")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  // Relations
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sender User @relation("CommunicationSender", fields: [senderId], references: [id])

  @@index([clubId, type, sentAt])
  @@index([clubId, priority])
  @@map("communications")
}

model MedicalRecord {
  id              String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId          String               @map("club_id") @db.Uuid
  athleteId       String               @map("athlete_id") @db.Uuid
  type            MedicalRecordType
  title           String
  description     String?
  data            Json                 @default("{}")
  recordDate      DateTime             @default(now()) @map("record_date") @db.Date
  expiryDate      DateTime?            @map("expiry_date") @db.Date
  isActive        Boolean              @default(true) @map("is_active")
  restrictions    String[]             @default([])
  recommendations String[]             @default([])
  attachments     Json                 @default("{}")
  confidentiality ConfidentialityLevel @default(RESTRICTED)
  recordedBy      String               @map("recorded_by") @db.Uuid
  approvedBy      String?              @map("approved_by") @db.Uuid
  notes           String?
  emergencyInfo   Json                 @default("{}") @map("emergency_info")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  club     Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  athlete  Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  recorder User    @relation("MedicalRecorder", fields: [recordedBy], references: [id])
  approver User?   @relation("MedicalApprover", fields: [approvedBy], references: [id])

  @@index([clubId, athleteId, isActive])
  @@index([clubId, type])
  @@map("medical_records")
}

model File {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId         String       @map("club_id") @db.Uuid
  uploadedBy     String       @map("uploaded_by") @db.Uuid
  fileName       String       @map("file_name")
  fileType       String       @map("file_type")
  fileSize       BigInt       @map("file_size")
  filePath       String       @map("file_path")
  category       FileCategory
  entityType     String?      @map("entity_type")
  entityId       String?      @map("entity_id") @db.Uuid
  description    String?
  tags           String[]     @default([])
  isPublic       Boolean      @default(false) @map("is_public")
  downloadCount  Int          @default(0) @map("download_count")
  lastAccessedAt DateTime?    @map("last_accessed_at")
  expiresAt      DateTime?    @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  club     Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  uploader User @relation("FileUploader", fields: [uploadedBy], references: [id])

  @@index([clubId, category])
  @@index([clubId, entityType, entityId])
  @@map("files")
}

// ============================================================================
// SYSTEM MODELS
// ============================================================================

model UserSession {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  clubId         String?  @map("club_id") @db.Uuid
  tokenHash      String   @unique @map("token_hash")
  deviceInfo     Json     @default("{}") @map("device_info")
  ipAddress      String?  @map("ip_address") @db.Inet
  userAgent      String?  @map("user_agent")
  isActive       Boolean  @default(true) @map("is_active")
  expiresAt      DateTime @map("expires_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("user_sessions")
}

model AuditLog {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clubId     String?  @map("club_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address") @db.Inet
  userAgent  String?  @map("user_agent")
  timestamp  DateTime @default(now())

  // Relations
  club Club? @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clubId, timestamp])
  @@index([userId, timestamp])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
