# API Gateway Environment Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
PORT=3000
NODE_ENV=development

# Microservices URLs
# These URLs define how the API Gateway connects to backend services
# In production, these should point to your orchestrator service names (e.g., Kubernetes services)
# In development, they default to localhost with standard ports

# Identity Service - Authentication & Authorization
IDENTITY_SERVICE_URL=http://localhost:3001

# Sports Service - Athletes, Training, Performance
SPORTS_SERVICE_URL=http://localhost:3002

# Club Management Service - Clubs, Teams, Memberships
CLUB_MANAGEMENT_URL=http://localhost:3003

# Communication Service - Notifications, Messages
COMMUNICATION_SERVICE_URL=http://localhost:3004

# Rate Limiting Configuration
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_SHORT_TTL=1
RATE_LIMIT_SHORT_MAX=3

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_TIMEOUT=60000
CIRCUIT_BREAKER_MONITORING_PERIOD=10000

# Logging
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:4200

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=1h
