# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sports_platform_dev"

# Service Ports
IDENTITY_SERVICE_PORT=3001
SPORTS_SERVICE_PORT=3002
API_GATEWAY_PORT=3000
CLUB_MANAGEMENT_PORT=3003
COMMUNICATION_PORT=3004

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production-please"
JWT_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Google OAuth (Update with your credentials)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# Server Configuration
PORT=3001
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:4200"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# Session Configuration
SESSION_SECRET="your-session-secret-key-change-in-production"
SESSION_EXPIRY=900000
REFRESH_SESSION_EXPIRY=604800000

# Security
BCRYPT_ROUNDS=12
