{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/apps", "<rootDir>/libs"],
  "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "apps/**/*.(t|j)s",
    "libs/**/*.(t|j)s",
    "!apps/**/*.spec.ts",
    "!apps/**/*.test.ts",
    "!libs/**/*.spec.ts",
    "!libs/**/*.test.ts",
    "!apps/**/main.ts",
    "!apps/**/test/**",
    "!libs/**/test/**",
    "!**/node_modules/**",
    "!**/dist/**"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "lcov", "html"],
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
  "moduleNameMapping": {
    "^@sports-platform/shared/auth$": "<rootDir>/libs/shared/auth/src",
    "^@sports-platform/shared/database$": "<rootDir>/libs/shared/database/src",
    "^@sports-platform/shared/common$": "<rootDir>/libs/shared/common/src"
  },
  "testTimeout": 30000,
  "maxWorkers": 1
}
