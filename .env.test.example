# Environment file for testing
# Copy this to .env.test and modify as needed

# Application Environment
NODE_ENV=test

# Database Configuration (Test)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sports_platform_test"

# JWT Configuration (Test)
JWT_SECRET=test-jwt-secret-for-unit-tests
JWT_EXPIRES_IN=15m

# Google OAuth Configuration (Test - Use test credentials)
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Session Configuration (Test)
SESSION_SECRET=test-session-secret

# Service Ports (Test)
IDENTITY_SERVICE_PORT=3001
SPORTS_SERVICE_PORT=3002
API_GATEWAY_PORT=3000
CLUB_MANAGEMENT_PORT=3003
COMMUNICATION_PORT=3004

# Redis Configuration (Test)
REDIS_URL=redis://localhost:6379/1

# Email Configuration (Test - Use mock service)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM="test@sports-platform.com"

# File Storage (Test)
UPLOAD_DIR=./test-uploads
MAX_FILE_SIZE=5MB

# Logging (Test)
LOG_LEVEL=error
LOG_FORMAT=json

# Rate Limiting (Test)
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=1000

# Feature Flags (Test)
ENABLE_SWAGGER=true
ENABLE_METRICS=false
ENABLE_TRACING=false